APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Supabase (backend only)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# SMS Gateway
SMS_GATEWAY_BASE_URL=https://app.sms-gateway.app/api/v1
SMS_GATEWAY_API_KEY=YOUR_NEW_SMS_GATEWAY_API_KEY

# Queue / app behavior
ENABLE_QUEUE=true
QUEUE_FLUSH_INTERVAL_SECONDS=30
LOG_LEVEL=info
